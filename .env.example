# ─────────────────────────────────────────────────────────────────────────────
# Trade Promo Optimization — Environment Variables
# Copy to .env and fill in values for your environment.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Provider selection (overrides config.yaml at runtime) ─────────────────────
STORAGE_PROVIDER=local           # local | s3 | azure | gcs
COMPUTE_PROVIDER=local           # local | databricks | emr | dataproc
LLM_PROVIDER=anthropic           # anthropic | bedrock | azure

# ── LLM credentials ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://my-resource.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── AWS (S3 storage, Bedrock LLM, EMR compute) ───────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=               # if using temporary credentials / role
AWS_REGION=us-east-1
AWS_PROFILE=                     # optional named profile from ~/.aws/credentials

S3_BUCKET=my-tpo-bucket

# ── Azure Storage (ADLS Gen2) ─────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT=mystorageaccount
AZURE_CONTAINER=tpo-data
# Leave blank to use DefaultAzureCredential (managed identity / az login)
# Set to a SAS token or connection string to override
AZURE_STORAGE_CREDENTIAL=

# ── GCP (GCS storage, Dataproc compute) ──────────────────────────────────────
GCP_PROJECT=my-gcp-project
GCP_REGION=us-central1
GCS_BUCKET=my-tpo-bucket
# Set path to service account JSON, or leave blank for ADC
GOOGLE_APPLICATION_CREDENTIALS=

# ── Databricks ────────────────────────────────────────────────────────────────
DATABRICKS_HOST=https://adb-xxxx.azuredatabricks.net
DATABRICKS_TOKEN=dapi...
DATABRICKS_CLUSTER_ID=

# ── Dataproc ──────────────────────────────────────────────────────────────────
DATAPROC_MASTER_URL=spark://my-cluster-m:7077
DATAPROC_CLUSTER=my-cluster
